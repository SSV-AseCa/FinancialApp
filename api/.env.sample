# ── Database ─────────────────────────────────────────────────────────────────
# Spring Boot reads these to connect to PostgreSQL when running locally.
# For tests, Testcontainers starts its own container automatically — these
# vars are NOT needed for `./gradlew test`.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ssv
SPRING_DATASOURCE_USERNAME=ssv
SPRING_DATASOURCE_PASSWORD=ssv

# ── External APIs ─────────────────────────────────────────────────────────────
# Required for integration tests that hit real endpoints.
# Also required at runtime for EDGAR and Yahoo Finance features.
EDGAR_API_KEY=
YAHOO_FINANCE_API_KEY=

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# AUTH0_DOMAIN: your tenant, e.g. dev-xxxx.us.auth0.com
# AUTH0_AUDIENCE: the API identifier registered in Auth0.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.ssvfinancial.com

# ── EDGAR-Rate-Limit ─────────────────────────────────────────────────────────────────────
EDGAR_BASE_URL=
EDGAR_USER_AGENT=
EDGAR_RATE_LIMIT_MAX_REQUESTS=
EDGAR_RATE_LIMIT_WINDOW_MILLIS=

# ── Yahoo Finance / Market Prices ─────────────────────────────────────────────
MARKET_PRICES_BASE_URL=https://query1.finance.yahoo.com
MARKET_PRICES_QUOTE_PATH=/v8/finance/chart/%s
# ── Database ─────────────────────────────────────────────────────────────────
# Spring Boot reads these to connect to PostgreSQL when running locally.
# For tests, Testcontainers starts its own container automatically — these
# vars are NOT needed for `./gradlew test`.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ssv
SPRING_DATASOURCE_USERNAME=ssv
SPRING_DATASOURCE_PASSWORD=ssv

# ── External APIs ─────────────────────────────────────────────────────────────
# Required for integration tests that hit real endpoints.
# Also required at runtime for EDGAR and Yahoo Finance features.
EDGAR_API_KEY=
YAHOO_FINANCE_API_KEY=

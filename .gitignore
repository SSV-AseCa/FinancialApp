.obsidian/

# local environment files — copy .env.sample to .env and fill in real values
.env
**/.env

# keep sample files tracked so new contributors know what vars are needed
!.env.sample
!**/.env.sample

# semantic-release sentinel files — written at publish time to signal a
# release happened; consumed by the Docker build step and never committed
**/.released-version

# staged APK produced by the release workflow before the GitHub release
# upload; must not be committed to the repo
apps/mobile/app-debug.apk

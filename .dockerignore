**/node_modules
**/dist
!packages/ui-core/dist
!packages/ui-core/dist/**
**/.git
**/.gradle
**/build
apps/mobile/android/app/build
apps/mobile/app-debug.apk

# Keep .env out of the build context so Vite config arrives only via build args
# (ARG -> ENV in the web Dockerfile), the same channel CI uses. Prevents a local
# .env from silently shadowing the build args.
**/.env
**/.env.*

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the backend API reachable from the browser.
# Vite exposes variables prefixed with VITE_ to client-side code.
VITE_API_BASE_URL=http://localhost:8080

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Auth0 application configuration
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_AUDIENCE=https://api.ssvfinancial.com
VITE_AUTH0_CLIENT_ID=your-client-id

# ── Cypress E2E Tests ─────────────────────────────────────────────────────────
# Dedicated Auth0 user credentials used by Cypress for programmatic login
# Note: Requires "Password" grant to be enabled in Auth0 App Advanced Settings
TEST_USER_EMAIL=cypress-test@ssvfinancial.com
TEST_USER_PASSWORD=your-secure-test-password

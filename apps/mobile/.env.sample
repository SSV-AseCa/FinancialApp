# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of the backend API reachable from the Capacitor WebView.
# Use 10.0.2.2 when targeting the Android emulator to reach host localhost.
VITE_API_BASE_URL=http://10.0.2.2:8080

# ── Auth ──────────────────────────────────────────────────────────────────────
# Set to 'true' to use MockAuthAdapter instead of Auth0 (required for Appium E2E).
VITE_USE_MOCK_AUTH=true

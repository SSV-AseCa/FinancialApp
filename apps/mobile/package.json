{
  "name": "ssv-mobile",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "wdio run appium/wdio.conf.ts",
    "preview": "vite preview",
    "sync:android": "cap sync android",
    "build:android:debug": "pnpm build && pnpm sync:android && cd android && ./gradlew assembleDebug",
    "test:e2e:android:local": "cross-env APPIUM_UDID=emulator-5554 wdio run appium/wdio.conf.ts",
    "test:e2e:android:docker": "cross-env APPIUM_UDID=localhost:5555 wdio run appium/wdio.conf.ts"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@ssv/ui-core": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.6",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.2.7",
    "vitest": "^4.1.6",
    "webdriverio": "^9.27.1"
  }
}
